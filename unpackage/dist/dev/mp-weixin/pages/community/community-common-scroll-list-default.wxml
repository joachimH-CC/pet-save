<view data-event-opts="{{[['tap',[['toPostDetail',['$0'],['item.postId']]]]]}}" class="item" bindtap="__e"><view class="user-info flex"><u--image vue-id="58d24f6c-4" src="{{item.avater}}" shape="circle" width="90rpx" height="90rpx" bind:__l="__l"></u--image><view style="margin:0 20rpx;"><u--text vue-id="58d24f6c-5" margin="16rpx 0 6rpx 0" bold="{{true}}" text="{{item.nickName}}" size="13" color="#494949" bind:__l="__l"></u--text><u--text vue-id="58d24f6c-6" text="{{item.createTime}}" size="10" color="#7e7f86" bind:__l="__l"></u--text></view></view><u--text vue-id="58d24f6c-7" lines="2" margin="10rpx" text="{{item.title}}" size="12" color="#494949" bind:__l="__l"></u--text><block wx:if="{{item.postPicture}}"><u--image vue-id="58d24f6c-8" src="{{item.postPicture.path}}" radius="20rpx" width="90%" height="300rpx" bind:__l="__l"></u--image></block><view class="flex"><block wx:if="{{item.isUserLike==1}}"><u-icon vue-id="58d24f6c-9" name="thumb-up-fill" color="#6887cb" labelPos="right" label="{{item.likeNum}}" labelSize="24rpx" bind:__l="__l"></u-icon></block><block wx:if="{{item.isUserLike==0}}"><u-icon vue-id="58d24f6c-10" name="thumb-up" color="#6887cb" labelPos="right" label="{{item.likeNum}}" labelSize="24rpx" bind:__l="__l"></u-icon></block><u-icon vue-id="58d24f6c-11" name="chat-fill" color="#6887cb" labelPos="right" label="{{item.commentNum}}" labelSize="24rpx" bind:__l="__l"></u-icon></view></view>