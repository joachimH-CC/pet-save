<view class="chat"><u-navbar vue-id="81f0b0be-1" leftText="{{title}}" title="{{nickName}}" autoBack="{{true}}" data-event-opts="{{[['^leftClick',[['backInfo']]]]}}" bind:leftClick="__e" bind:__l="__l" vue-slots="{{['left','center']}}"><view class="flex top-nav" slot="left"><u-icon vue-id="{{('81f0b0be-2')+','+('81f0b0be-1')}}" name="arrow-leftward" color="#85a2e4" bind:__l="__l"></u-icon><u--text vue-id="{{('81f0b0be-3')+','+('81f0b0be-1')}}" margin="6rpx" bold="{{true}}" text="返回" size="12" color="#6e90d7" bind:__l="__l"></u--text></view><view class="flex" slot="center"><u--text vue-id="{{('81f0b0be-4')+','+('81f0b0be-1')}}" margin="6rpx" bold="{{true}}" text="{{nickName}}" size="13" color="#6e90d7" bind:__l="__l"></u--text></view></u-navbar><view class="chat-container"><scroll-view class="chat-scroll vue-ref" scroll-y="{{true}}" scroll-top="{{scrollTop}}" scroll-with-animation="{{true}}" data-ref="chatScroll"><view id="scroll-view-content"><block wx:for="{{messages}}" wx:for-item="message" wx:for-index="index" wx:key="index"><view><block wx:if="{{!message.isSelf}}"><view class="flex" style="margin-bottom:10rpx;"><block wx:if="{{chatPartnerId==0}}"><view class="icon"><u-icon vue-id="{{'81f0b0be-5-'+index}}" name="bell-fill" size="50rpx" color="#597dca" bind:__l="__l"></u-icon></view></block><block wx:if="{{chatPartnerId==-1}}"><view class="icon-green"><u-icon vue-id="{{'81f0b0be-6-'+index}}" name="home-fill" size="50rpx" color="#36b248" bind:__l="__l"></u-icon></view></block><block wx:if="{{chatPartnerId>0}}"><u-avatar vue-id="{{'81f0b0be-7-'+index}}" size="35" mode="aspectFill" src="{{otherAvatar}}" customStyle="margin: 3px 5px 3px 0" bind:__l="__l"></u-avatar></block><view><u--text vue-id="{{'81f0b0be-8-'+index}}" margin="0 20rpx 6rpx 0" text="{{message.sendTime}}" size="10" color="#a6a6a6" bind:__l="__l"></u--text><view class="text" style="margin-right:20rpx;"><block wx:if="{{message.title}}"><u--text vue-id="{{'81f0b0be-9-'+index}}" margin="6rpx" bold="{{true}}" text="{{message.title}}" size="12" color="#6e90d7" bind:__l="__l"></u--text></block><block wx:if="{{message.content}}"><u--text vue-id="{{'81f0b0be-10-'+index}}" text="{{message.content}}" size="12" bind:__l="__l"></u--text></block></view><block wx:if="{{message.isPic}}"><view class="sys-imag"><u--image vue-id="{{'81f0b0be-11-'+index}}" radius="10rpx" src="{{message.pictureUrl}}" width="590rpx" height="380rpx" showLoading="true" bind:__l="__l"></u--image></view></block></view></view></block><block wx:else><view class="flex-end" style="margin-bottom:10rpx;"><view><u--text vue-id="{{'81f0b0be-12-'+index}}" margin="0 6rpx 6rpx 20rpx" text="{{message.sendTime}}" size="10" color="#a6a6a6" bind:__l="__l"></u--text><view class="text my" style="margin-left:20rpx;">{{''+message.content+''}}</view></view><u-avatar vue-id="{{'81f0b0be-13-'+index}}" size="35" mode="aspectFill" src="{{myAvatar}}" customStyle="margin: 3px 5px" bind:__l="__l"></u-avatar></view></block></view></block></view></scroll-view><block wx:if="{{chatPartnerId>0}}"><view class="input-part flex"><u--textarea bind:input="__e" vue-id="81f0b0be-14" border="none" autoHeight="{{true}}" disabled="{{chatPartnerId<=0}}" value="{{chatContent}}" data-event-opts="{{[['^input',[['__set_model',['','chatContent','$event',[]]]]]]}}" bind:__l="__l"></u--textarea><u-button vue-id="81f0b0be-15" text="发送" color="#6c95e0" size="small" disabled="{{chatPartnerId<=0}}" data-event-opts="{{[['^click',[['sendMsg']]]]}}" bind:click="__e" bind:__l="__l"></u-button></view></block><block wx:else><view class="input-part flex"><u--text vue-id="81f0b0be-16" prefixIcon="info-circle" margin="0 200rpx 20rpx 230rpx" iconStyle="{{$root.a0}}" text="系统信息,不可回复" size="15" color="#a6a6a6" bind:__l="__l"></u--text></view></block></view></view>