.chat {
  background-color: #f4f4f5;
}
.chat .top-nav {
  padding: 10rpx;
  background-color: #ebf3ff;
  border-radius: 50rpx;
}
.chat .chat-container {
  margin-top: 200rpx;
  height: calc(100vh - 330rpx);
}
.chat .chat-container .chat-scroll {
  height: 100%;
}
.chat .chat-container .chat-scroll #scroll-view-content {
  box-sizing: border-box;
  padding: 0 0 30rpx 0;
}
.chat .chat-container .sys-imag {
  width: 590rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  margin: 20rpx 0;
  background-color: #fff;
}
.chat .chat-container .icon {
  margin: 0 10rpx;
}
.chat .chat-container .icon .u-icon.data-v-172979f2 {
  padding: 16rpx !important;
  box-sizing: border-box;
  border-radius: 50%;
  background-color: #fcfeff;
}
.chat .chat-container .icon-green {
  margin: 0 10rpx;
}
.chat .chat-container .icon-green .u-icon.data-v-172979f2 {
  padding: 26rpx !important;
  box-sizing: border-box;
  border-radius: 50%;
  background-color: #f0fbf1;
}
.chat .chat-container .text {
  padding: 10rpx 20rpx;
  line-height: 50rpx;
  background-color: #fff;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #4e4e4f;
}
.chat .chat-container .my {
  background-color: #6c95e0;
  color: #fff;
}
.chat .chat-container .input-part {
  width: 100%;
  padding: 30rpx 10rpx;
  box-sizing: border-box;
  background-color: #fff;
  position: fixed;
  bottom: 0rpx;
}
.chat .chat-container .input-part .u-textarea {
  padding: 6rpx 20rpx;
  box-sizing: border-box;
  border-radius: 50rpx;
  background-color: #f4f4f5;
}
.chat .chat-container .input-part .u-button {
  margin-left: 20rpx;
  width: 160rpx;
}
