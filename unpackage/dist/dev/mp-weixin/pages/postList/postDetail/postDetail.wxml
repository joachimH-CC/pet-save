<view class="post-detail content"><block wx:if="{{loading}}"><u-loadmore vue-id="22aa1d62-1" status="loading" bind:__l="__l"></u-loadmore></block><block wx:if="{{postInfo}}"><view data-ref="postRef" class="post-container vue-ref"><view class="user-info flex"><u--image vue-id="22aa1d62-2" src="{{postInfo.avatar}}" shape="circle" width="90rpx" height="90rpx" bind:__l="__l"></u--image><view style="margin:0 20rpx;"><u--text vue-id="22aa1d62-3" margin="16rpx 0 6rpx 0" bold="{{true}}" text="{{postInfo.nickName}}" size="13" color="#494949" bind:__l="__l"></u--text><u--text vue-id="22aa1d62-4" text="{{postInfo.createTime}}" size="10" color="#7e7f86" bind:__l="__l"></u--text></view></view><u--text vue-id="22aa1d62-5" margin="10rpx 4rpx" text="{{postInfo.title}}" size="13" bold="{{true}}" color="#6887cb" bind:__l="__l"></u--text><view class="post-content"><u--text vue-id="22aa1d62-6" text="{{postInfo.content}}" size="13" bind:__l="__l"></u--text></view><block wx:if="{{$root.g0}}"><u-grid vue-id="22aa1d62-7" border="{{false}}" col="3" bind:__l="__l" vue-slots="{{['default']}}"><block wx:for="{{postInfo.postFiles}}" wx:for-item="item" wx:for-index="i" wx:key="i"><u-grid-item vue-id="{{('22aa1d62-8-'+i)+','+('22aa1d62-7')}}" bind:__l="__l" vue-slots="{{['default']}}"><u--image vue-id="{{('22aa1d62-9-'+i)+','+('22aa1d62-8-'+i)}}" src="{{item.path}}" width="220rpx" height="220rpx" bind:__l="__l"></u--image></u-grid-item></block></u-grid></block><view class="flex"><block wx:if="{{postInfo.isUserLike==1}}"><u-icon vue-id="22aa1d62-10" name="thumb-up-fill" color="#6887cb" labelPos="right" label="{{postInfo.likeNum}}" labelSize="24rpx" data-event-opts="{{[['^click',[['handleDislikePost']]]]}}" bind:click="__e" bind:__l="__l"></u-icon></block><block wx:if="{{postInfo.isUserLike==0}}"><u-icon vue-id="22aa1d62-11" name="thumb-up" color="#6887cb" labelPos="right" label="{{postInfo.likeNum}}" labelSize="24rpx" data-event-opts="{{[['^click',[['handleLikePost']]]]}}" bind:click="__e" bind:__