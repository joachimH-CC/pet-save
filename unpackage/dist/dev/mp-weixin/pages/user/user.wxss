.user .header {
  padding: 30rpx;
  box-sizing: border-box;
  background: linear-gradient(to right, #7198cf, #5372c1);
  border-radius: 20rpx;
  box-shadow: 2rpx 2rpx 9rpx 10rpx rgba(128, 151, 202, 0.2);
}
.user .user-container {
  margin-top: 20rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 20rpx;
  box-shadow: 2rpx 2rpx 9rpx 10rpx rgba(128, 151, 202, 0.2);
}
.user .user-container .u-cell {
  margin: 10rpx 0;
}
.user .user-container .u-cell__title-text {
  font-size: 26rpx !important;
}
.user .user-container .u-icon__icon {
  color: #5372c1 !important;
  margin-right: 6rpx;
  padding: 6rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  background-color: #e9f1fb;
}
.user .user-container .u-icon__icon--info {
  background-color: #fff;
}
.user .user-container .u-button {
  width: 300rpx;
}
.user .u-image {
  border: 4rpx solid #fff;
}
