.match-list .match-item {
  margin-bottom: 30rpx;
  overflow: hidden;
  border-bottom: 2rpx solid #5a7eca;
}
.match-list .match-item .match-reason {
  box-sizing: border-box;
  padding: 20rpx 30rpx;
  margin: 20rpx 0;
  background-color: #f8f9fa;
  border-radius: 20rpx;
  font-size: 24rpx;
  border-left: #95b4e2 solid 6rpx;
}
.match-list .match-item .match-reason .u-tag__text {
  font-size: 20rpx !important;
}
.match-list .match-item .match-reason .reason-title {
  font-weight: 600;
}
.match-list .match-item .pet-item {
  background-color: #fff;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  height: 202rpx;
  display: flex;
}
.match-list .match-item .pet-item .pet-item-content {
  position: relative;
  margin: 10rpx 20rpx;
  display: flex;
  flex-direction: column;
}
.match-list .match-item .pet-item .pet-item-content .pet-type {
  font-weight: 600;
}
.match-list .match-item .pet-item .pet-item-content .u-icon__icon {
  font-weight: 600 !important;
  color: #5a7eca !important;
}
.match-list .match-item .pet-item .pet-item-content .discribe {
  margin: 10rpx 0;
  font-size: 25rpx;
  color: #7b7b7b;
}
.match-list .match-item .pet-item .pet-item-content .adopt-status {
  position: absolute;
  right: 0rpx;
  top: 0rpx;
}
.match-list .match-item .pet-item .pet-item-content .adopt-status .u-tag--mini {
  width: 80rpx;
  height: 28rpx !important;
}
.match-list .match-item .pet-item .pet-item-content .adopt-status .u-tag__text--mini {
  font-size: 24rpx !important;
}
.match-list .match-item .pet-item .pet-item-content .pet-label {
  padding: 10rpx 0;
  box-sizing: border-box;
  border-bottom: 1px solid #c3c3c3;
}
.match-list .match-item .pet-item .pet-item-content .pet-label .u-tag--mini {
  height: 20rpx !important;
}
.match-list .match-item .pet-item .pet-item-content .pet-label .u-tag__text--mini {
  font-size: 20rpx !important;
}
.match-list .match-item .pet-item .pet-item-content .pet-label .tag {
  margin-right: 10rpx;
}
.match-list .match-item .pet-item .pet-item-content .woman .u-icon__icon {
  color: #d08b92 !important;
}
.match-list .match-item .pet-item .pet-item-content .pet-status {
  margin-top: 10rpx;
}
.match-list .match-item .pet-item .pet-item-content .pet-status .tag {
  margin-right: 16rpx;
}
.match-list .match-item .pet-item .pet-item-content .pet-status .u-tag--mini {
  height: 25rpx !important;
}
.match-list .match-item .pet-item .pet-item-content .pet-status .u-icon__icon {
  font-size: 20rpx !important;
}
.match-list .match-item .pet-item .pet-item-content .pet-status .u-tag__text--mini {
  font-size: 18rpx !important;
  font-weight: 600;
}
.match-list .match-item .pet-item image {
  border-radius: 0 0 20rpx 0;
  width: 200rpx;
  height: 200rpx;
}
