<view class="match-item"><block wx:if="{{item}}"><view data-event-opts="{{[['tap',[['toPetDetail',['$0'],['item.petId']]]]]}}" class="pet-item" bindtap="__e"><u--image vue-id="aebf35e8-3" src="{{item.petPicture}}" width="200rpx" height="200rpx" radius="20rpx" bind:__l="__l"></u--image><view class="pet-item-content"><view class="{{[(item.sex==1)?'woman':'']}}"><block wx:if="{{item.sex==1}}"><u--text vue-id="aebf35e8-4" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="woman" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==0}}"><u--text vue-id="aebf35e8-5" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="man" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==2}}"><u--text vue-id="aebf35e8-6" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" bind:__l="__l"></u--text></block></view><label class="discribe _span">{{item.age+"岁|"+item.petTypeName+"|"+item.sizeName}}</label><block wx:if="{{item.labels}}"><view class="pet-label flex"><block wx:for="{{item.labels}}" wx:for-item="lab" wx:for-index="i" wx:key="i"><view class="tag"><u-tag vue-id="{{'aebf35e8-7-'+i}}" text="{{lab.lab}}" plain="{{true}}" size="mini" type="{{lab.tagType}}" bind:__l="__l"></u-tag></view></block></view></block><view class="pet-status flex"><view class="tag"><u-tag vue-id="aebf35e8-8" icon="{{item.sterilizationStatus==1?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.sterilizationStatus==1?'已绝育':'未绝育'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="aebf35e8-9" icon="{{item.dewormNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.dewormNum>0?'已驱虫':'未驱虫'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="aebf35e8-10" icon="{{item.vaccineNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.vaccineNum>0?'已疫苗':'未疫苗'}}" size="mini" bind:__l="__l"></u-tag></view></view></view></view></block><view class="match-reason just-space-be"><view><label class="reason-title _span">匹配原因:</label><view class="_p">{{item.reason}}</view></view><u-tag vue-id="aebf35e8-11" bgColor="#5a7eca" size="mini" shape="circle" text="{{'匹配度: '+item.matchScore+'%'}}" bind:__l="__l"></u-tag></view></view>