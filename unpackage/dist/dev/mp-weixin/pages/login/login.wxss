.login {
  padding: 50rpx 56rpx;
  box-sizing: border-box;
}
.login .u-form-item {
  margin: 10rpx 0;
}
.login .u-form-item .role .u-button {
  margin: 0 10rpx;
  border: 2rpx solid #dfdfdf !important;
}
.login .u-form-item .role .u-button__text {
  color: #000;
}
.login .u-icon__icon {
  color: #6685ca !important;
}
.login .u-button {
  margin: 0 10rpx;
}
.login .u-button.code-btn {
  width: 200rpx;
}
.login .u-button--normal.btn {
  background-color: #6685ca !important;
}
.login .u-form-item__body__right__message {
  margin: 0 !important;
}
.login .title {
  text-align: center;
  margin-bottom: 30rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #3b4e76;
}
.login .title .tip {
  font-weight: 500;
  font-size: 28rpx;
  color: #a0a0a0;
}
