<view class="pet-detail"><block wx:if="{{petData}}"><view class="pet-detail pet-content"><u-swiper vue-id="c18b6b82-1" height="380rpx" radius="20rpx" list="{{carouselList}}" keyName="image" indicator="{{true}}" indicatorMode="line" circular="{{true}}" bind:__l="__l"></u-swiper><view class="{{[(petData.sex==1)?'woman':'']}}" style="margin-top:20rpx;"><block wx:if="{{petData.sex==1}}"><u--text vue-id="c18b6b82-2" margin="0 6rpx 6rpx 0" text="{{petData.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="woman" bind:__l="__l"></u--text></block><block wx:if="{{petData.sex==0}}"><u--text vue-id="c18b6b82-3" margin="0 6rpx 6rpx 0" text="{{petData.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="man" bind:__l="__l"></u--text></block><block wx:if="{{petData.sex==2}}"><u--text vue-id="c18b6b82-4" margin="0 6rpx 6rpx 0" text="{{petData.varietyLabel}}" bold="{{true}}" size="16" bind:__l="__l"></u--text></block></view><label class="discribe _span">{{petData.age+"岁|"+petData.petTypeName+"|"+$root.m0}}</label><block wx:if="{{$root.g0>0}}"><view class="pet-label flex"><block wx:for="{{$root.l0}}" wx:for-item="lab" wx:for-index="i" wx:key="i"><view class="tag"><u-tag vue-id="{{'c18b6b82-5-'+i}}" text="{{lab.$orig}}" plain="{{true}}" size="mini" type="{{lab.m1}}" bind:__l="__l"></u-tag></view></block></view></block><view class="pet-status flex"><view class="tag"><u-tag vue-id="c18b6b82-6" icon="{{petData.sterilizationStatus==1?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{petData.sterilizationStatus==1?'已绝育':'未绝育'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="c18b6b82-7" icon="{{petData.dewormNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{petData.dewormNum>0?'已驱虫':'未驱虫'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="c18b6b82-8" icon="{{petData.vaccineNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{petData.vaccineNum>0?'已疫苗':'未疫苗'}}" size="mini" bind:__l="__l"></u-tag></view></view><view class="address flex"><u-icon vue-id="c18b6b82-9" name="map-fill" bind:__l="__l"></u-icon><label class="_span">{{petData.address}}</label></view><block wx:if="{{role==2}}"><view class="just-space-be adopt-btn"><u-button vue-id="c18b6b82-10" color="#6685ca" disabled="{{isAdopt}}" text="申请领养" size="small" data-event-opts="{{[['^click',[['toAdoptPet']]]]}}" bind:click="__e" bind:__l="__l"></u-button><u-button class="collect" vue-id="c18b6b82-11" icon="{{collectIcon}}" size="small" data-event-opts="{{[['^click',[['collectPet']]]]}}" bind:click="__e" bind:__l="__l"></u-button></view></block></view></block><view class="healthy-detail pet-content"><view class="_h3">健康状况</view><block wx:if="{{petData}}"><u-grid vue-id="c18b6b82-12" border="{{false}}" col="2" bind:__l="__l" vue-slots="{{['default']}}"><u-grid-item vue-id="{{('c18b6b82-13')+','+('c18b6b82-12')}}" bind:__l="__l" vue-slots="{{['default']}}"><u--text vue-id="{{('c18b6b82-14')+','+('c18b6b82-13')}}" margin="10rpx 0 6rpx 0" bold="{{true}}" text="体重状况" size="12" color="#a4a4a4" bind:__l="__l"></u--text><u--text vue-id="{{('c18b6b82-15')+','+('c18b6b82-13')}}" text="{{petData.weight+'kg左右'}}" size="12" bind:__l="__l"></u--text></u-grid-item><u-grid-item vue-id="{{('c18b6b82-16')+','+('c18b6b82-12')}}" bind:__l="__l" vue-slots="{{['default']}}"><u--text vue-id="{{('c18b6b82-17')+','+('c18b6b82-16')}}" margin="10rpx 0 6rpx 0" bold="{{true}}" text="疫苗次数" size="12" color="#a4a4a4" bind:__l="__l"></u--text><u--text vue-id="{{('c18b6b82-18')+','+('c18b6b82-16')}}" text="{{petData.vaccineNum+'次'}}" size="12" bind:__l="__l"></u--text></u-grid-item><u-grid-item vue-id="{{('c18b6b82-19')+','+('c18b6b82-12')}}" bind:__l="__l" vue-slots="{{['default']}}"><u--text vue-id="{{('c18b6b82-20')+','+('c18b6b82-19')}}" margin="10rpx 0 6rpx 0" bold="{{true}}" text="皮毛状况" size="12" color="#a4a4a4" bind:__l="__l"></u--text><u--text vue-id="{{('c18b6b82-21')+','+('c18b6b82-19')}}" text="{{petData.coatColor}}" size="12" bind:__l="__l"></u--text></u-grid-item><u-grid-item vue-id="{{('c18b6b82-22')+','+('c18b6b82-12')}}" bind:__l="__l" vue-slots="{{['default']}}"><u--text vue-id="{{('c18b6b82-23')+','+('c18b6b82-22')}}" margin="10rpx 0 6rpx 0" bold="{{true}}" text="驱虫次数" size="12" color="#a4a4a4" bind:__l="__l"></u--text><u--text vue-id="{{('c18b6b82-24')+','+('c18b6b82-22')}}" text="{{petData.dewormNum+'次'}}" size="12" bind:__l="__l"></u--text></u-grid-item></u-grid></block><block wx:else><view><u-empty vue-id="c18b6b82-25" mode="data" text="还没有健康状况数据^_^" bind:__l="__l"></u-empty></view></block></view><view class="care-detail pet-content"><view class="_h3">护理记录</view><block wx:if="{{$root.g1>0}}"><u-steps vue-id="c18b6b82-26" activeColor="#6685ca" current="{{$root.g2}}" direction="column" dot="true" bind:__l="__l" vue-slots="{{['default']}}"><block wx:for="{{$root.l1}}" wx:for-item="item" wx:for-index="index" wx:key="index"><u-steps-item vue-id="{{('c18b6b82-27-'+index)+','+('c18b6b82-26')}}" title="{{item.$orig.createTime}}" bind:__l="__l" vue-slots="{{['desc']}}"><view slot="desc"><view class="_p">{{item.m2}}</view><view class="_p">{{item.$orig.contnet}}</view></view></u-steps-item></block></u-steps></block><block wx:else><view><u-empty vue-id="c18b6b82-28" mode="data" text="还没有护理记录^_^" bind:__l="__l"></u-empty></view></block></view><view class="character-detail pet-content"><view class="_h3">性格描述</view><view class="_p">{{rescueInfo.description||'暂无性格描述信息'}}</view></view><view class="adopt-detail pet-content"><view class="_h3">领养需知</view><view class="_p">{{rescueInfo.adoptionNotice||'暂无领养需知信息'}}</view></view><view class="save-story pet-content"><view class="_h3">救助故事</view><view class="_p">{{rescueInfo.rescueStory||'暂无救助故事信息'}}</view></view></view>