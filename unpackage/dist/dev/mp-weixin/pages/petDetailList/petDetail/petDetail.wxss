.pet-detail {
  padding: 0rpx 30rpx 20rpx;
}
.pet-detail .pet-content {
  margin-top: 20rpx;
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}
.pet-detail .pet-detail {
  margin-top: 0rpx;
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}
.pet-detail .pet-detail .pet-type {
  font-weight: 600;
}
.pet-detail .pet-detail .u-icon__icon {
  font-weight: 600 !important;
  color: #5a7eca !important;
}
.pet-detail .pet-detail .discribe {
  margin: 10rpx 0;
  font-size: 25rpx;
  color: #7b7b7b;
}
.pet-detail .pet-detail .adopt-status {
  position: absolute;
  right: 0rpx;
  top: 0rpx;
}
.pet-detail .pet-detail .adopt-status .u-tag--mini {
  width: 80rpx;
  height: 28rpx !important;
}
.pet-detail .pet-detail .adopt-status .u-tag__text--mini {
  font-size: 24rpx !important;
}
.pet-detail .pet-detail .pet-label {
  padding: 10rpx 0;
  box-sizing: border-box;
  border-bottom: 1px solid #c3c3c3;
}
.pet-detail .pet-detail .pet-label .u-tag--mini {
  height: 20rpx !important;
}
.pet-detail .pet-detail .pet-label .u-tag--info--plain {
  border: #67aee4 2rpx solid !important;
}
.pet-detail .pet-detail .pet-label .u-tag__text--info--plain {
  color: #67aee4;
}
.pet-detail .pet-detail .pet-label .u-tag__text--mini {
  font-size: 20rpx !important;
}
.pet-detail .pet-detail .pet-label .tag {
  margin-right: 10rpx;
}
.pet-detail .pet-detail .woman .u-icon__icon {
  color: #d08b92 !important;
}
.pet-detail .pet-detail .pet-status {
  margin-top: 10rpx;
}
.pet-detail .pet-detail .pet-status .tag {
  margin-right: 16rpx;
}
.pet-detail .pet-detail .pet-status .u-tag--mini {
  height: 25rpx !important;
}
.pet-detail .pet-detail .pet-status .u-icon__icon {
  font-size: 20rpx !important;
}
.pet-detail .pet-detail .pet-status .u-tag__text--mini {
  font-size: 18rpx !important;
  font-weight: 600;
}
.pet-detail .pet-detail .serve {
  font-weight: 600;
  font-size: 24rpx;
  margin: 10rpx 0;
}
.pet-detail .pet-detail .address {
  margin: 10rpx 0;
  font-size: 22rpx;
  color: #7b7b7b;
  font-weight: 600;
  border-bottom: 1px solid #c3c3c3;
  padding-bottom: 14rpx;
  box-sizing: border-box;
}
.pet-detail .pet-detail .address ._span {
  margin-top: 6rpx;
}
.pet-detail .pet-detail .address .u-icon {
  margin-right: 10rpx;
}
.pet-detail .pet-detail .address .u-icon__icon {
  color: #6685ca !important;
}
.pet-detail .pet-detail .adopt-btn {
  margin: 20rpx 0;
}
.pet-detail .pet-detail .adopt-btn .u-button {
  margin-right: 20rpx;
  border-radius: 10rpx;
}
.pet-detail .pet-detail .adopt-btn .u-icon__icon {
  color: #6685ca !important;
}
.pet-detail .pet-detail .adopt-btn .u-button--small:last-child {
  width: 240rpx !important;
}
.pet-detail ._h3 {
  margin-bottom: 10rpx;
  padding: 10rpx 0;
  box-sizing: border-box;
  font-weight: 600;
  border-bottom: 2rpx solid #c3c3c3;
}
.pet-detail ._p {
  font-size: 24rpx;
  margin: 10rpx 0;
}
