<view class="adopt-detail content"><view class="adopt-detail-container"><view class="care-detail pet-content"><block wx:if="{{petData}}"><view data-event-opts="{{[['tap',[['toPetDetail',['$event']]]]]}}" class="pet-item" bindtap="__e"><u--image vue-id="28821ba0-1" src="{{petData.petPicture}}" width="200rpx" height="200rpx" radius="20rpx" bind:__l="__l"></u--image><view class="pet-item-content"><view class="{{[(petData.sex==1)?'woman':'']}}" style="margin-top:20rpx;"><block wx:if="{{petData.sex==1}}"><u--text vue-id="28821ba0-2" margin="0 6rpx 6rpx 0" text="{{petData.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="woman" bind:__l="__l"></u--text></block><block wx:if="{{petData.sex==0}}"><u--text vue-id="28821ba0-3" margin="0 6rpx 6rpx 0" text="{{petData.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="man" bind:__l="__l"></u--text></block><block wx:if="{{petData.sex==2}}"><u--text vue-id="28821ba0-4" margin="0 6rpx 6rpx 0" text="{{petData.varietyLabel}}" bold="{{true}}" size="16" bind:__l="__l"></u--text></block></view><label class="discribe _span">{{petData.age+"岁|"+petData.petTypeName+"|"+$root.m0}}</label><block wx:if="{{$root.g0>0}}"><view class="pet-label flex"><block wx:for="{{$root.l0}}" wx:for-item="lab" wx:for-index="i" wx:key="i"><view class="tag"><u-tag vue-id="{{'28821ba0-5-'+i}}" text="{{lab.$orig}}" plain="{{true}}" size="mini" type="{{lab.m1}}" bind:__l="__l"></u-tag></view></block></view></block><view class="pet-status flex"><view class="tag"><u-tag vue-id="28821ba0-6" icon="{{petData.sterilizationStatus==1?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{petData.sterilizationStatus==1?'已绝育':'未绝育'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="28821ba0-7" icon="{{petData.dewormNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{petData.dewormNum>0?'已驱虫':'未驱虫'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="28821ba0-8" icon="{{petData.vaccineNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{petData.vaccineNum>0?'已疫苗':'未疫苗'}}" size="mini" bind:__l="__l"></u-tag></view></view></view></view></block><block wx:if="{{petData}}"><view class="apply-tag flex"><label class="_span">申请状态:</label><u-tag vue-id="28821ba0-9" text="{{$root.m2}}" plain="{{true}}" plainFill="{{true}}" type="{{$root.m3}}" size="mini" bind:__l="__l"></u-tag></view></block><view class="_h3">申请流程</view><u-steps vue-id="28821ba0-10" activeColor="#6685ca" current="{{$root.g1}}" direction="column" bind:__l="__l" vue-slots="{{['default']}}"><block wx:for="{{reviewList}}" wx:for-item="step" wx:for-index="index" wx:key="index"><u-steps-item vue-id="{{('28821ba0-11-'+index)+','+('28821ba0-10')}}" title="{{step.processName}}" bind:__l="__l" vue-slots="{{['desc']}}"><view class="_p" slot="desc">{{step.createTime}}</view></u-steps-item></block></u-steps></view></view></view>