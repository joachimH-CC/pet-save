.adopt-detail .adopt-detail-container {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 20rpx;
}
.adopt-detail .adopt-detail-container .u-steps-item__content {
  margin: 20rpx;
  padding: 10rpx;
  border-radius: 10rpx;
  background-color: #f4f4f5;
  box-sizing: border-box;
}
.adopt-detail .adopt-detail-container .apply-tag {
  margin: 20rpx 0;
}
.adopt-detail .adopt-detail-container .apply-tag ._span {
  line-height: 46rpx;
  font-size: 26rpx;
  font-weight: 600;
}
.adopt-detail .adopt-detail-container .apply-tag .u-tag--mini {
  width: 80rpx;
  margin-left: 20rpx;
}
.adopt-detail .adopt-detail-container ._h3 {
  font-size: 26rpx;
  margin-bottom: 10rpx;
  padding: 10rpx 0;
  box-sizing: border-box;
  font-weight: 600;
  border-bottom: 2rpx solid #c3c3c3;
}
.adopt-detail .adopt-detail-container ._p {
  font-size: 24rpx;
  margin: 10rpx 0;
}
.adopt-detail .adopt-detail-container .pet-item {
  margin-bottom: 20rpx;
  display: flex;
  overflow: hidden;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content {
  margin: 10rpx 20rpx;
  display: flex;
  flex-direction: column;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-type {
  font-weight: 600;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .u-icon__icon {
  font-weight: 600 !important;
  color: #5a7eca !important;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .discribe {
  margin: 10rpx 0;
  font-size: 25rpx;
  color: #7b7b7b;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-label {
  padding: 10rpx 0;
  box-sizing: border-box;
  border-bottom: 1px solid #c3c3c3;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-label .u-tag--mini {
  height: 24rpx !important;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-label .u-tag--info--plain {
  border: #67aee4 2rpx solid !important;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-label .u-tag__text--info--plain {
  color: #67aee4;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-label .u-tag__text--mini {
  font-size: 20rpx !important;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-label .tag {
  margin-right: 10rpx;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-status {
  margin-top: 10rpx;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-status .tag {
  margin-right: 16rpx;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-status .u-tag--mini {
  height: 25rpx !important;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-status .u-icon__icon {
  font-size: 20rpx !important;
}
.adopt-detail .adopt-detail-container .pet-item .pet-item-content .pet-status .u-tag__text--mini {
  font-size: 18rpx !important;
  font-weight: 600;
}
