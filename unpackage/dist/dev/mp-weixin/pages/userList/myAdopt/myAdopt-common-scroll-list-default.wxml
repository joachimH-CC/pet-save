<view class="adopt-item"><block wx:if="{{item}}"><view class="pet-item"><u--image vue-id="6e51d84c-3" src="{{item.petPicture}}" width="200rpx" height="200rpx" radius="20rpx" bind:__l="__l"></u--image><view class="pet-item-content"><view class="{{[(item.sex==1)?'woman':'']}}"><block wx:if="{{item.sex==1}}"><u--text vue-id="6e51d84c-4" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="woman" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==0}}"><u--text vue-id="6e51d84c-5" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="man" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==2}}"><u--text vue-id="6e51d84c-6" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" bind:__l="__l"></u--text></block></view><label class="discribe _span">{{item.age+"岁|"+item.petTypeName+"|"+item.sizeName}}</label><block wx:if="{{item.labels}}"><view class="pet-label flex"><block wx:for="{{item.labels}}" wx:for-item="lab" wx:for-index="i" wx:key="i"><view class="tag"><u-tag vue-id="{{'6e51d84c-7-'+i}}" text="{{lab.lab}}" plain="{{true}}" size="mini" type="{{lab.tagType}}" bind:__l="__l"></u-tag></view></block></view></block><view class="pet-status flex"><view class="tag"><u-tag vue-id="6e51d84c-8" icon="{{item.sterilizationStatus==1?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.sterilizationStatus==1?'已绝育':'未绝育'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="6e51d84c-9" icon="{{item.dewormNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.dewormNum>0?'已驱虫':'未驱虫'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="6e51d84c-10" icon="{{item.vaccineNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.vaccineNum>0?'已疫苗':'未疫苗'}}" size="mini" bind:__l="__l"></u-tag></view></view></view></view></block><view class="just-space-be"><u-tag vue-id="6e51d84c-11" text="{{item.status}}" plain="{{true}}" plainFill="{{true}}" type="{{item.statusType}}" size="mini" bind:__l="__l"></u-tag><view class="flex fuc"><u-button vue-id="6e51d84c-12" icon="info-circle-fill" text="查看详情" color="#e6f4ff" size="mini" data-event-opts="{{[['^click',[['toAdoptDetail',['$0','$1'],['item.applyId','item.petId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button><block wx:if="{{item.reviewStatus==1&&item.contractStatus!=1}}"><u-button vue-id="6e51d84c-13" icon="edit-pen-fill" text="签署协议" type="warning" size="mini" data-event-opts="{{[['^click',[['comfirmContract',['$0'],['item.applyId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button></block><block wx:if="{{item.reviewStatus==0}}"><u-button vue-id="6e51d84c-14" icon="trash-fill" text="取消申请" size="mini" type="error" data-event-opts="{{[['^click',[['cancelApply',['$0'],['item.applyId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button></block></view></view></view>