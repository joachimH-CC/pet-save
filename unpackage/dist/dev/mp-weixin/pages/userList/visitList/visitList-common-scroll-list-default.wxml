<block wx:if="{{item}}"><view class="saver-pet-item"><view class="pet-item"><u--image vue-id="4bb86cd0-3" src="{{item.petPicture}}" width="200rpx" height="200rpx" radius="20rpx" bind:__l="__l"></u--image><view class="pet-item-content"><view class="adopt-status"><u-tag vue-id="4bb86cd0-4" text="{{'已完成'+item.returnNum+'次回访'}}" plain="{{true}}" type="{{item.returnNum>0?'success':'warning'}}" size="mini" bind:__l="__l"></u-tag></view><view class="{{[(item.sex==1)?'woman':'']}}"><block wx:if="{{item.sex==1}}"><u--text vue-id="4bb86cd0-5" margin="0 6rpx 6rpx 0" text="{{item.variety}}" bold="{{true}}" size="16" suffixIcon="woman" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==0}}"><u--text vue-id="4bb86cd0-6" margin="0 6rpx 6rpx 0" text="{{item.variety}}" bold="{{true}}" size="16" suffixIcon="man" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==2}}"><u--text vue-id="4bb86cd0-7" margin="0 6rpx 6rpx 0" text="{{item.variety}}" bold="{{true}}" size="16" bind:__l="__l"></u--text></block></view><u--text vue-id="4bb86cd0-8" margin="6rpx 0" text="{{item.age+'岁 | '+item.petTypeName+' | '+(item.size===0?'小型':item.size===1?'中型':item.size===2?'大型':'未知')}}" size="11" color="#787878" bind:__l="__l"></u--text><u--text vue-id="4bb86cd0-9" margin="10rpx 0 10rpx 0" bold="{{true}}" text="{{'领养人: '+item.nickName}}" size="13" color="#787878" bind:__l="__l"></u--text><u--text vue-id="4bb86cd0-10" margin="6rpx 0" text="{{'领养时间: '+item.applyTime}}" size="11" color="#787878" bind:__l="__l"></u--text></view></view><view class="flex-end fuc"><u-button vue-id="4bb86cd0-11" icon="file-text-fill" text="回访记录" color="#e6f4ff" size="mini" data-event-opts="{{[['^click',[['toVisitDetail',['$0'],['item.applyId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button></view></view></block>