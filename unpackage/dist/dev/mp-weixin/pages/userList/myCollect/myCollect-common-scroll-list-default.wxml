<view class="pet-item-container"><view data-event-opts="{{[['tap',[['toPetDetail',['$0'],['item.petId']]]]]}}" class="pet-item" bindtap="__e"><u--image vue-id="7c6a4aa6-3" src="{{item.petPicture}}" width="200rpx" height="200rpx" radius="20rpx" bind:__l="__l"></u--image><view class="pet-item-content"><view class="{{[(item.sex==1)?'woman':'']}}"><block wx:if="{{item.sex==1}}"><u--text vue-id="7c6a4aa6-4" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="woman" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==0}}"><u--text vue-id="7c6a4aa6-5" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" suffixIcon="man" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==2}}"><u--text vue-id="7c6a4aa6-6" margin="0 6rpx 6rpx 0" text="{{item.varietyLabel}}" bold="{{true}}" size="16" bind:__l="__l"></u--text></block></view><label class="discribe _span">{{item.age+"岁|"+item.petTypeName+"|"+item.sizeName}}</label><block wx:if="{{item.labels}}"><view class="pet-label flex"><block wx:for="{{item.labels}}" wx:for-item="lab" wx:for-index="i" wx:key="i"><view class="tag"><u-tag vue-id="{{'7c6a4aa6-7-'+i}}" text="{{lab.lab}}" plain="{{true}}" size="mini" type="{{lab.tagType}}" bind:__l="__l"></u-tag></view></block></view></block><view class="pet-status flex"><view class="tag"><u-tag vue-id="7c6a4aa6-8" icon="{{item.sterilizationStatus==1?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.sterilizationStatus==1?'已绝育':'未绝育'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="7c6a4aa6-9" icon="{{item.dewormNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.dewormNum>0?'已驱虫':'未驱虫'}}" size="mini" bind:__l="__l"></u-tag></view><view class="tag"><u-tag vue-id="7c6a4aa6-10" icon="{{item.vaccineNum>0?'checkmark':'close'}}" borderColor="#e9f1fb" bgColor="#e9f1fb" color="#5a7eca" text="{{item.vaccineNum>0?'已疫苗':'未疫苗'}}" size="mini" bind:__l="__l"></u-tag></view></view></view></view><view class="apply-btn"><u-button vue-id="7c6a4aa6-11" size="mini" text="{{item.adoptReminder==1?'取消领养提醒':'设置领养提醒'}}" color="#e9f1fb" data-event-opts="{{[['^click',[['handleAdoptNotice',['$0'],['item.petId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button><u-button vue-id="7c6a4aa6-12" size="mini" text="取消收藏" plain="{{true}}" data-event-opts="{{[['^click',[['handleCancelCollect',['$0'],['item.petId']]]]]}}" catch:click="__e" bind:__l="__l"></u-button></view></view>