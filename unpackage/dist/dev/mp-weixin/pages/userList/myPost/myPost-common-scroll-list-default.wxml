<view data-event-opts="{{[['tap',[['toPostDetail',['$0'],['item.postId']]]]]}}" class="item" bindtap="__e"><view class="user-info flex"><u--image vue-id="35c0e1b8-2" src="{{item.avater}}" shape="circle" width="90rpx" height="90rpx" bind:__l="__l"></u--image><view style="margin:0 20rpx;"><u--text vue-id="35c0e1b8-3" margin="16rpx 0 6rpx 0" bold="{{true}}" text="{{item.nickName}}" size="13" color="#494949" bind:__l="__l"></u--text><u--text vue-id="35c0e1b8-4" text="{{item.createTime}}" size="10" color="#7e7f86" bind:__l="__l"></u--text></view></view><u--text vue-id="35c0e1b8-5" lines="2" margin="10rpx" text="{{item.title}}" size="12" color="#494949" bind:__l="__l"></u--text><u--image vue-id="35c0e1b8-6" src="{{item.postImages[0]}}" radius="20rpx" width="300rpx" height="200rpx" bind:__l="__l"></u--image><view class="flex"><block wx:if="{{item.isUserLike==0}}"><u-icon vue-id="35c0e1b8-7" name="thumb-up" color="#6887cb" labelPos="right" label="{{item.likeNum}}" labelSize="24rpx" bind:__l="__l"></u-icon></block><block wx:if="{{item.isUserLike==1}}"><u-icon vue-id="35c0e1b8-8" name="thumb-up-fill" color="#6887cb" labelPos="right" label="{{item.likeNum}}" labelSize="24rpx" bind:__l="__l"></u-icon></block><u-icon vue-id="35c0e1b8-9" name="chat-fill" color="#6887cb" labelPos="right" label="{{item.commentNum}}" labelSize="24rpx" bind:__l="__l"></u-icon><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="flex" style="margin-left:240rpx;" catchtap="__e"><u-button vue-id="35c0e1b8-10" icon="edit-pen-fill" text="编辑" color="#e6f4ff" size="mini" data-event-opts="{{[['^click',[['editPost',['$0'],['item.postId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button><u-button vue-id="35c0e1b8-11" icon="trash-fill" text="删除" size="mini" type="error" data-event-opts="{{[['^click',[['delPost',['$0'],['item.postId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button></view></view></view>