<block wx:if="{{item}}"><view class="saver-pet-item"><view data-event-opts="{{[['tap',[['toApplyDetail',['$0'],['item.applyId']]]]]}}" class="pet-item" bindtap="__e"><u--image vue-id="02bc5f08-3" src="{{item.petPicture}}" width="200rpx" height="200rpx" radius="20rpx" bind:__l="__l"></u--image><view class="pet-item-content"><block wx:if="{{item.reviewStatus!==undefined&&item.reviewStatus!==null}}"><view class="adopt-status"><u-tag vue-id="02bc5f08-4" text="{{item.statusText}}" plain="{{true}}" plainFill="{{true}}" type="{{item.statusType}}" size="mini" bind:__l="__l"></u-tag></view></block><view class="{{[(item.sex==1)?'woman':'']}}"><block wx:if="{{item.sex==1}}"><u--text vue-id="02bc5f08-5" margin="0 6rpx 6rpx 0" text="{{item.variety}}" bold="{{true}}" size="16" suffixIcon="woman" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==0}}"><u--text vue-id="02bc5f08-6" margin="0 6rpx 6rpx 0" text="{{item.variety}}" bold="{{true}}" size="16" suffixIcon="man" bind:__l="__l"></u--text></block><block wx:if="{{item.sex==2}}"><u--text vue-id="02bc5f08-7" margin="0 6rpx 6rpx 0" text="{{item.variety}}" bold="{{true}}" size="16" bind:__l="__l"></u--text></block></view><u--text vue-id="02bc5f08-8" margin="6rpx 0" text="{{item.age+'岁 | '+item.petTypeName+' | '+(item.size===0?'小型':item.size===1?'中型':item.size===2?'大型':'未知')}}" size="11" color="#787878" bind:__l="__l"></u--text><u--text vue-id="02bc5f08-9" margin="10rpx 0 10rpx 0" bold="{{true}}" text="{{'申请人: '+item.nickName}}" size="13" color="#787878" bind:__l="__l"></u--text><u--text vue-id="02bc5f08-10" margin="6rpx 0" text="{{'申请时间: '+item.applyTime}}" size="11" color="#787878" bind:__l="__l"></u--text></view></view><view class="ai-advice"><u--text vue-id="02bc5f08-11" bold="{{true}}" text="{{'AI匹配度:'+item.aiMatchData+'%'}}" size="11" color="#6786c9" bind:__l="__l"></u--text></view><view class="just-space-be"><u-button vue-id="02bc5f08-12" icon="server-fill" text="在线聊天" color="#e6f4ff" size="mini" data-event-opts="{{[['^click',[['toChat',['$0'],['item']]]]]}}" bind:click="__e" bind:__l="__l"></u-button><view class="flex fuc"><block wx:if="{{item.reviewStatus==0}}"><u-button vue-id="02bc5f08-13" icon="close-circle-fill" text="拒绝" size="mini" type="error" data-event-opts="{{[['^click',[['refuseApply',['$0'],['item.applyId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button></block><block wx:if="{{item.reviewStatus==0}}"><u-button vue-id="02bc5f08-14" icon="checkmark-circle-fill" text="通过" type="success" plain="{{true}}" size="mini" data-event-opts="{{[['^click',[['approvedApply',['$0'],['item.applyId']]]]]}}" bind:click="__e" bind:__l="__l"></u-button></block></view></view></view></block>