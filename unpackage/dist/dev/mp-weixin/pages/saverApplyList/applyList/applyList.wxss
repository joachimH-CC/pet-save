.apply-list .pet-item {
  padding: 20rpx;
  box-sizing: border-box;
  border-bottom: 2rpx solid #aac3e2;
  display: flex;
  overflow: hidden;
  position: relative;
}
.apply-list .pet-item .pet-item-content {
  margin: 10rpx 20rpx;
  display: flex;
  flex-direction: column;
}
.apply-list .pet-item .pet-item-content .pet-type {
  font-weight: 600;
}
.apply-list .pet-item .pet-item-content .u-icon__icon {
  font-weight: 600 !important;
  color: #5a7eca !important;
}
.apply-list .pet-item .pet-item-content .discribe {
  margin: 10rpx 0;
  font-size: 25rpx;
  color: #7b7b7b;
}
.apply-list .pet-item .pet-item-content .adopt-status {
  position: absolute;
  right: 0rpx;
  top: 20rpx;
}
.apply-list .pet-item .pet-item-content .adopt-status .u-tag--mini {
  height: 28rpx !important;
}
.apply-list .pet-item .pet-item-content .adopt-status .u-tag__text--mini {
  font-size: 24rpx !important;
}
.apply-list .apply-list-container .saver-pet-item {
  margin-bottom: 20rpx;
  background-color: #fff;
  padding: 20rpx;
  box-sizing: border-box;
  border-bottom: 2rpx solid #aac3e2;
}
.apply-list .apply-list-container .saver-pet-item .ai-advice {
  border-radius: 10rpx;
  box-sizing: border-box;
  margin: 0 0 20rpx 0;
  padding: 10rpx;
  background-color: #f2f5f8;
}
.apply-list .apply-list-container .saver-pet-item .u-button--warning {
  background-color: #fcf8f2;
  color: #efa73a !important;
  border-color: #fcf8f2;
  width: 200rpx;
  margin: 2rpx;
}
.apply-list .apply-list-container .saver-pet-item .u-button--warning .u-icon__icon {
  color: #f9ae3d !important;
}
.apply-list .apply-list-container .saver-pet-item .u-button--mini {
  color: #6786c9 !important;
  margin-left: 10rpx;
  width: 200rpx;
  margin: 2rpx;
}
.apply-list .apply-list-container .saver-pet-item .u-button--mini .u-icon__icon {
  color: #6786c9 !important;
}
.apply-list .apply-list-container .saver-pet-item .fuc .u-button--mini {
  color: #6786c9 !important;
  margin-left: 10rpx;
  width: 160rpx;
}
.apply-list .apply-list-container .saver-pet-item .fuc .u-button--mini .u-icon__icon {
  color: #6786c9 !important;
}
.apply-list .apply-list-container .saver-pet-item .fuc .u-button--success {
  background-color: #eef8ec;
  color: #5ac725 !important;
  border-color: #eef8ec;
}
.apply-list .apply-list-container .saver-pet-item .fuc .u-button--success .u-icon__icon {
  color: #5ac725 !important;
}
.apply-list .apply-list-container .saver-pet-item .fuc .u-button--error {
  background-color: #fcf0f0;
  color: #d94048 !important;
  border-color: #fcf0f0;
}
.apply-list .apply-list-container .saver-pet-item .fuc .u-button--error .u-icon__icon {
  color: #d94048 !important;
}
.apply-list .apply-list-container .saver-pet-item .pet-item {
  border-bottom: none;
}
.apply-list .refuse-pop {
  width: 600rpx;
  padding: 30rpx;
}
.apply-list .refuse-pop .btn {
  margin: 20rpx 0s;
}
.apply-list .refuse-pop .btn .u-button--info {
  margin-right: 20rpx;
}
.apply-list .refuse-pop .btn .u-button--mini {
  width: 300rpx !important;
}
