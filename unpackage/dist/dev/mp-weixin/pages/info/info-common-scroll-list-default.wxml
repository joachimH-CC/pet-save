<view data-event-opts="{{[['tap',[['toChat',['$0'],['item']]]]]}}" class="item" bindtap="__e"><view class="flex"><block wx:if="{{item.chatPartnerId==0}}"><view class="icon"><u-icon vue-id="773ba800-3" name="bell-fill" size="50rpx" color="#597dca" bind:__l="__l"></u-icon></view></block><block wx:if="{{item.chatPartnerId==-1}}"><view class="icon-green"><u-icon vue-id="773ba800-4" name="home-fill" size="50rpx" color="#36b248" bind:__l="__l"></u-icon></view></block><block wx:if="{{item.chatPartnerId>0}}"><u-avatar vue-id="773ba800-5" size="49" mode="aspectFill" src="{{item.avatar}}" bind:__l="__l"></u-avatar></block><view class="msg-title"><view class="{{[(item.unReadCount>0)?'badge':'']}}"><u--text vue-id="773ba800-6" margin="16rpx 0 0 0" bold="{{true}}" text="{{item.nickName}}" size="13" color="#494949" bind:__l="__l"></u--text></view><u--text vue-id="773ba800-7" margin="10rpx 0 0 0" text="{{item.content}}" lines="1" size="10" color="#7e7f86" bind:__l="__l"></u--text></view><u-icon class="time" vue-id="773ba800-8" name="{{item.lastSendTime}}" size="22rpx" bind:__l="__l"></u-icon></view></view>