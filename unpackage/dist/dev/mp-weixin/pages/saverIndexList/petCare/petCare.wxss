.pet-care {
  height: 95.5vh;
  background-color: #f4f4f5;
}
.pet-care .pet-care-container .u-button {
  margin: 10rpx 0;
  width: 300rpx;
}
.pet-care .pet-care-container .u-button .u-icon__icon {
  color: #6887cb;
  font-weight: 600;
}
.pet-care .pet-care-container .u-button .u-button__text {
  color: #6887cb;
  font-weight: 600;
}
.pet-care .pet-care-container .care-item {
  margin-bottom: 30rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background-color: #fff;
}
.pet-care .pet-care-container .care-item .u-icon__icon {
  color: #6887cb !important;
  font-weight: 600;
}
.pet-care .add-record {
  padding: 30rpx;
}
.pet-care .edit-health {
  padding: 10rpx 60rpx;
  background-color: #fff;
}
.pet-care .edit-health .minus {
  width: 22px;
  height: 22px;
  border-width: 1px;
  border-color: #E6E6E6;
  border-style: solid;
  border-top-left-radius: 100px;
  border-top-right-radius: 100px;
  border-bottom-left-radius: 100px;
  border-bottom-right-radius: 100px;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}
.pet-care .edit-health .input {
  padding: 0 10px;
}
.pet-care .edit-health .plus {
  width: 22px;
  height: 22px;
  background-color: #6887cb;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}
.pet-care .edit-health .u-form-item {
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}
.pet-care .edit-health .switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.pet-care .edit-health .pop-btn-group {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.pet-care .edit-health .u-number-box {
  width: 200rpx;
}
