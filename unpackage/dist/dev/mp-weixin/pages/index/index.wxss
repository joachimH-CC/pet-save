.index {
  height: 92vh;
}
.index .type .u-radio-group .u-row {
  display: grid !important;
  grid-template-columns: repeat(3, 1fr);
}
.index .add-btn {
  position: fixed;
  bottom: 130rpx;
  right: 10rpx;
}
.index .bac {
  width: 100%;
  z-index: -1;
  position: absolute;
  top: 0px;
  height: 400rpx;
  background: linear-gradient(to bottom, #597dc9, #fff);
}
.index .index-content {
  padding: 30rpx;
  height: 86vh;
}
.index .index-content .choose {
  margin: 20rpx 0;
}
.index .index-content .choose .btn {
  padding: 20rpx;
  text-align: center;
  box-sizing: border-box;
  border-radius: 20rpx;
  height: 200rpx;
  width: 330rpx;
  background: linear-gradient(to right, #6688d3, #b3cafe);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-size: 25rpx;
  font-weight: 600;
}
.index .index-content .choose .knowledge {
  background: linear-gradient(to right, #d08b92, #e7d4f9);
}
.index .index-content .pet-container .pet-title {
  margin: 30rpx 0 20rpx 0;
  line-height: 60rpx;
}
.index .index-content .pet-item {
  padding: 20rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #aac3e2;
  display: flex;
  overflow: hidden;
}
.index .index-content .pet-item .pet-item-content {
  position: relative;
  margin: 10rpx 20rpx;
  display: flex;
  flex-direction: column;
}
.index .index-content .pet-item .pet-item-content .pet-type {
  font-weight: 600;
}
.index .index-content .pet-item .pet-item-content .u-icon__icon {
  font-weight: 600 !important;
  color: #5a7eca !important;
}
.index .index-content .pet-item .pet-item-content .discribe {
  margin: 10rpx 0;
  font-size: 25rpx;
  color: #7b7b7b;
}
.index .index-content .pet-item .pet-item-content .adopt-status {
  position: absolute;
  right: -70rpx;
  top: 0rpx;
}
.index .index-content .pet-item .pet-item-content .adopt-status .u-tag--mini {
  width: 80rpx;
  height: 28rpx !important;
}
.index .index-content .pet-item .pet-item-content .adopt-status .u-tag__text--mini {
  font-size: 24rpx !important;
}
.index .index-content .pet-item .pet-item-content .pet-label {
  padding: 10rpx 0;
  box-sizing: border-box;
  border-bottom: 1px solid #c3c3c3;
}
.index .index-content .pet-item .pet-item-content .pet-label .u-tag--mini {
  height: 24rpx !important;
}
.index .index-content .pet-item .pet-item-content .pet-label .u-tag--info--plain {
  border: #67aee4 2rpx solid !important;
}
.index .index-content .pet-item .pet-item-content .pet-label .u-tag__text--info--plain {
  color: #67aee4;
}
.index .index-content .pet-item .pet-item-content .pet-label .u-tag__text--mini {
  font-size: 20rpx !important;
}
.index .index-content .pet-item .pet-item-content .pet-label .tag {
  margin-right: 10rpx;
}
.index .index-content .pet-item .pet-item-content .woman .u-icon__icon {
  color: #d08b92 !important;
}
.index .index-content .pet-item .pet-item-content .pet-status {
  margin-top: 10rpx;
}
.index .index-content .pet-item .pet-item-content .pet-status .tag {
  margin-right: 16rpx;
}
.index .index-content .pet-item .pet-item-content .pet-status .u-tag--mini {
  height: 25rpx !important;
}
.index .index-content .pet-item .pet-item-content .pet-status .u-icon__icon {
  font-size: 20rpx !important;
}
.index .index-content .pet-item .pet-item-content .pet-status .u-tag__text--mini {
  font-size: 18rpx !important;
  font-weight: 600;
}
.index .index-content .u-subsection {
  margin-top: 50rpx;
}
.index .index-content .saver-pet-item {
  margin-bottom: 20rpx;
  background-color: #fff;
  padding: 10rpx 0;
  box-sizing: border-box;
  border-bottom: 2rpx solid #aac3e2;
}
.index .index-content .saver-pet-item .u-button--warning {
  background-color: #fcf8f2;
  color: #efa73a !important;
  border-color: #fcf8f2;
  width: 200rpx;
  margin: 2rpx;
}
.index .index-content .saver-pet-item .u-button--warning .u-icon__icon {
  color: #f9ae3d !important;
}
.index .index-content .saver-pet-item .fuc .u-button--mini {
  color: #6786c9 !important;
  margin-left: 10rpx;
}
.index .index-content .saver-pet-item .fuc .u-button--mini .u-icon__icon {
  color: #6786c9 !important;
}
.index .index-content .saver-pet-item .fuc .u-button--error {
  background-color: #fcf0f0;
  color: #d94048 !important;
  border-color: #fcf0f0;
}
.index .index-content .saver-pet-item .fuc .u-button--error .u-icon__icon {
  color: #d94048 !important;
}
.index .index-content .saver-pet-item .pet-border {
  border-bottom: none;
}
.index .index-content .saver-border {
  margin-bottom: 0rpx;
  border-bottom: none;
}
.index .index-content .search {
  padding: 10rpx 50rpx 0;
}
.index .index-content .search .u-form-item {
  margin-top: 20rpx;
}
.index .index-content .search .u-button {
  width: 500rpx !important;
}
.index .index-content .search text {
  font-size: 26rpx !important;
}
.index .type-scroll {
  max-height: 200rpx;
  overflow-y: auto;
  padding-right: 10rpx;
}
.index .type-scroll .u-radio-group .u-row {
  display: grid !important;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}
.index .type-scroll::-webkit-scrollbar {
  width: 6rpx;
}
.index .type-scroll::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}
.index .type-scroll::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}
.index .type-scroll::-webkit-scrollbar-thumb:hover {
  background: #a1a1a1;
}
