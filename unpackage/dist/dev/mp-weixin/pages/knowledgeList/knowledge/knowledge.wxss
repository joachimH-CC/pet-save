.knowledge {
  background-color: #f8f9fa;
}
.knowledge ._h3 {
  margin-bottom: 10rpx;
  padding: 10rpx 0;
  box-sizing: border-box;
  font-weight: 600;
  border-bottom: 2rpx solid #c3c3c3;
}
.knowledge .header {
  padding: 20rpx;
  box-sizing: border-box;
  background: linear-gradient(to right, #6988cb, #5372c1);
  border-radius: 20rpx;
  box-shadow: 2rpx 2rpx 9rpx 10rpx rgba(128, 151, 202, 0.2);
}
.knowledge .header .u-image {
  border: 4rpx solid #fff;
}
.knowledge .header .u-tag--small {
  width: 170rpx !important;
  margin: 14rpx 0 !important;
  padding: 10rpx 16rpx;
}
.knowledge .header .u-tag__text--small {
  font-size: 24rpx !important;
}
.knowledge .knowledge-container {
  padding: 20rpx;
  margin-top: 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #ffffff;
}
.knowledge .knowledge-container .knowledge-content {
  margin: 20rpx 0;
}
.knowledge .knowledge-container .knowledge-content .item {
  padding: 14rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #f4f4f5;
  box-sizing: border-box;
  border-radius: 20rpx;
}
.knowledge .knowledge-container .knowledge-content .item .u-icon {
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #e3f2fd;
}
.knowledge .knowledge-container .knowledge-content .item .essay-msg {
  width: 100%;
  margin-left: 20rpx;
}
.knowledge .knowledge-container .knowledge-content .item .essay-msg .class-top .u-tag--mini {
  width: 74rpx !important;
  height: 30rpx;
  margin: 10rpx 0;
}
.knowledge .knowledge-container .knowledge-content .item .essay-msg .u-icon {
  padding: 0;
  background-color: #fff;
  margin-right: 6rpx;
}
.knowledge .knowledge-container .knowledge-content .item .essay-msg .u-tag__text--mini {
  font-size: 18rpx !important;
}
.knowledge .knowledge-container .knowledge-content .item .essay-msg .u-tag--mini {
  width: 40rpx !important;
  height: 30rpx;
  margin: 10rpx 0;
}
.knowledge .knowledge-container .knowledge-content .item .essay-msg .u-icon__icon {
  color: #6988cb !important;
}
